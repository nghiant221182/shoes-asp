@model List<shoes_asp.Models.Cart>

@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal grandTotal = Model.Sum(x => x.TotalPrice);
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}
<div class="colorlib-product">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <h2 class="mb-4">Giỏ hàng của bạn</h2>

                @if (Model.Count == 0)
                {
                    <div class="alert alert-warning text-center">
                        Chưa có sản phẩm nào trong giỏ hàng.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered text-center align-middle">
                            <thead>
                                <tr>
                                    <th>Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Size</th>
                                    <th>Giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td style="width:120px;">
                                            <img src="~/images/@item.Product?.Image" alt="@item.Product?.Name" style="width:80px; height:80px; object-fit:cover;" />
                                        </td>
                                        <td>@item.Product?.Name</td>
                                        <td>@item.SelectedSize</td>
                                        <td>@item.Product?.Price.ToString("N0") VNĐ</td>
                                        <td>
                                            <a asp-controller="Cart" asp-action="Decrease" asp-route-cartId="@item.CartId" class="btn btn-sm btn-outline-secondary">-</a>

                                            <span style="margin:0 10px;">@item.Quantity</span>

                                            <a asp-controller="Cart" asp-action="Increase" asp-route-cartId="@item.CartId" class="btn btn-sm btn-outline-secondary">+</a>
                                        </td>
                                        <td>@item.TotalPrice.ToString("N0") VNĐ</td>
                                        <td>
                                            <a asp-controller="Cart" asp-action="Remove" asp-route-cartId="@item.CartId" class="btn btn-sm btn-danger">
                                                Xóa
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="text-right mt-4">
                        <h4>Tổng cộng: <strong>@grandTotal.ToString("N0") VNĐ</strong></h4>
                    </div>
                }
            </div>
        </div>
    </div>
</div>