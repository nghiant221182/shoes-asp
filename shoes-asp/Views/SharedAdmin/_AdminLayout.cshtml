<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Quản trị</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            background: #f5f6fa;
            font-family: Arial, sans-serif;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 250px;
            background: #1e293b;
            color: #fff;
            padding: 20px 0;
        }

            .admin-sidebar h3 {
                text-align: center;
                margin-bottom: 25px;
                font-size: 22px;
                font-weight: bold;
            }

            .admin-sidebar ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .admin-sidebar ul li {
                    margin: 0;
                }

                    .admin-sidebar ul li a {
                        display: block;
                        padding: 14px 20px;
                        color: #cbd5e1;
                        text-decoration: none;
                        transition: 0.2s;
                    }

                        .admin-sidebar ul li a:hover,
                        .admin-sidebar ul li a.active {
                            background: #334155;
                            color: #fff;
                        }

        .admin-main {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .admin-header {
            background: #fff;
            padding: 15px 25px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .admin-content {
            padding: 25px;
        }

        .admin-card {
            background: #fff;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .admin-user a {
            text-decoration: none;
            margin-left: 12px;
        }
    </style>
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var userName = Context.Session.GetString("UserName");
    }

    <div class="admin-wrapper">
        <aside class="admin-sidebar">
            <h3>ADMIN PANEL</h3>

            <ul>
                <li>
                    <a asp-controller="AdminProduct" asp-action="Index"
                       class="@(currentController == "AdminProduct" ? "active" : "")">
                        Quản lý sản phẩm
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminOrder" asp-action="Index"
                       class="@(currentController == "AdminOrder" ? "active" : "")">
                        Quản lý đơn hàng
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminCategory" asp-action="Index"
                       class="@(currentController == "AdminCategory" ? "active" : "")">
                        Quản lý danh mục
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminBrand" asp-action="Index"
                       class="@(currentController == "AdminBrand" ? "active" : "")">
                        Quản lý thương hiệu
                    </a>
                </li>

                <li>
                    <a asp-controller="Home" asp-action="Index">
                        Về trang người dùng
                    </a>
                </li>
            </ul>
        </aside>

        <div class="admin-main">
            <header class="admin-header">
                <div>
                    <strong>@ViewData["Title"]</strong>
                </div>

                <div class="admin-user">
                    Xin chào, <strong>@userName</strong>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-danger">
                        Đăng xuất
                    </a>
                </div>
            </header>

            <main class="admin-content">
                <div class="admin-card">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/bootstrap.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>