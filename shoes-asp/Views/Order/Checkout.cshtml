@model shoes_asp.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Đặt hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="colorlib-product">
    <div class="container">
        <div class="row">
            <div class="col-md-7">
                <h3 class="mb-4">Thông tin đặt hàng</h3>

                <form asp-action="Checkout" method="post">
                    <div class="form-group">
                        <label>Người nhận</label>
                        <input asp-for="ReceiverName" class="form-control" />
                        <span asp-validation-for="ReceiverName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Số điện thoại</label>
                        <input asp-for="ReceiverPhone" class="form-control" />
                        <span asp-validation-for="ReceiverPhone" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Địa chỉ giao hàng</label>
                        <input asp-for="ShippingAddress" class="form-control" />
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Ghi chú</label>
                        <textarea asp-for="Note" class="form-control" rows="4"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Xác nhận đặt hàng
                    </button>
                </form>
            </div>

            <div class="col-md-5">
                <h3 class="mb-4">Sản phẩm trong đơn</h3>

                <div class="border p-3">
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="d-flex justify-content-between mb-3">
                            <div>
                                <strong>@item.Product?.Name</strong><br />
                                SL: @item.Quantity
                                @if (!string.IsNullOrEmpty(item.SelectedSize))
                                {
                                    <span> - Size: @item.SelectedSize</span>
                                }
                            </div>
                            <div>
                                @item.TotalPrice.ToString("N0") VNĐ
                            </div>
                        </div>
                    }

                    <hr />
                    <h4 class="text-right">
                        Tổng tiền: <strong>@Model.GrandTotal.ToString("N0") VNĐ</strong>
                    </h4>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}