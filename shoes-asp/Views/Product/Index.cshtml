@model IEnumerable<shoes_asp.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="colorlib-product">
    <div class="container">
        <div class="row">
            <div class="col-sm-8 offset-sm-2 text-center colorlib-heading colorlib-heading-sm">
                <h2>Tất cả sản phẩm</h2>

                @if (!string.IsNullOrEmpty(ViewBag.Keyword))
                {
                    <p>Kết quả tìm kiếm cho: <strong>@ViewBag.Keyword</strong></p>
                }

                @if (ViewBag.CategoryName != null)
                {
                    <p>Danh mục đang chọn: <strong>@ViewBag.CategoryName</strong></p>
                }
            </div>
        </div>
        @if (ViewBag.CategoryId != null)
        {
            <div class="row mb-4">
                <div class="col-12 text-center">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">
                        Xem tất cả sản phẩm
                    </a>
                </div>
            </div>
        }

        <div class="row row-pb-md">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-3 col-lg-3 mb-4 text-center">
                        <div class="product-entry border">
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@item.ProductId"
                               class="prod-img">
                                <img src="~/images/@item.Image" class="img-fluid" alt="@item.Name">
                            </a>

                            <div class="desc">
                                <h2>
                                    <a asp-controller="Product"
                                       asp-action="Details"
                                       asp-route-id="@item.ProductId">
                                        @item.Name
                                    </a>
                                </h2>

                                <p>@item.Brand?.Name - @item.Category?.Name</p>
                                <p><strong>Size:</strong> @item.Size</p>

                                @{
                                    var fullStars = (int)Math.Floor(item.Rate);
                                    var hasHalfStar = item.Rate - fullStars >= 0.5;
                                    var emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
                                }

                                <p class="mb-2">
                                    <span class="rate">
                                        @for (int i = 0; i < fullStars; i++)
                                        {
                                            <i class="icon-star-full"></i>
                                        }

                                        @if (hasHalfStar)
                                        {
                                            <i class="icon-star-half"></i>
                                        }

                                        @for (int i = 0; i < emptyStars; i++)
                                        {
                                            <i class="icon-star-empty"></i>
                                        }

                                        (@item.Rate.ToString("0.0") / 5)
                                    </span>
                                </p>

                                <span class="price">@item.Price.ToString("N0") VNĐ</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <h4>Không tìm thấy sản phẩm phù hợp.</h4>
                </div>
            }
        </div>
    </div>
</div>

<div class="colorlib-partner">
    <div class="container">
        <div class="row">
            <div class="col-sm-8 offset-sm-2 text-center colorlib-heading colorlib-heading-sm">
                <h2>Thương hiệu nổi bật</h2>
            </div>
        </div>

        <div class="row">
            <div class="col partner-col text-center">
                <img src="~/images/brand-1.jpg" class="img-fluid" alt="Nike">
            </div>
            <div class="col partner-col text-center">
                <img src="~/images/brand-2.jpg" class="img-fluid" alt="Adidas">
            </div>
            <div class="col partner-col text-center">
                <img src="~/images/brand-3.jpg" class="img-fluid" alt="Puma">
            </div>
        </div>
    </div>
</div>